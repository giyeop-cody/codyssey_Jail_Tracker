{
  "name": "SECOM Dashboard",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Dashboard",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "cd dashboard && npm install",
  // Codespaces는 GITHUB_REPOSITORY와 기본 GITHUB_TOKEN을 자동 주입한다.
  // Actions Secret 수정 권한이 있는 PAT는 Codespaces Secret GH_PAT_SYNC로 받는다.
  // GH_PAT_SYNC가 있으면 앱의 GITHUB_TOKEN으로 우선 사용하고, 없으면 기본 토큰을 사용한다.
  "postStartCommand": "cd dashboard && GITHUB_TOKEN=\"${GH_PAT_SYNC:-$GITHUB_TOKEN}\" npm start",
  "waitFor": "postCreateCommand",
  "secrets": {
    "GH_PAT_SYNC": {
      "description": "codyssey_Jail_Tracker의 Actions Secret을 수정할 수 있는 GitHub PAT. 로그인 시 JSESSIONID를 CODYSSEY_SESSION으로 저장합니다."
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    },
    "codespaces": {
      "openFiles": ["README.md"]
    }
  }
}
